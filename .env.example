# Frontend → backend
# INTERNAL_API_URL is used by server components (Next container -> backend container).
# NEXT_PUBLIC_API_URL is exposed to the browser (host -> backend via published port).
INTERNAL_API_URL=http://backend:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
